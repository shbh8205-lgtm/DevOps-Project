// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// הגדרת ה-Enums
enum GameStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ParticipantRole {
  PLAYER
  CAPTAIN
  REFEREE
  SPECTATOR
}

// 1. מודל משתמש במערכת (User)
model User {
  id       Int    @id @default(autoincrement())
  username String
  email    String @unique

  // קשר One-to-Many למודל ההשתתפות
  participations GameParticipant[]
}

// 2. מודל ישות המייצגת משחק (Game)
model Game {
  id     Int        @id @default(autoincrement())
  title  String
  status GameStatus @default(PENDING) // ערך ברירת מחדל

  // קשר One-to-Many למודל ההשתתפות
  participants GameParticipant[]
}

// 3. טבלת קשר מפורשת (GameParticipant) - מנהלת את ה-Many-to-Many
model GameParticipant {
  id    Int             @id @default(autoincrement())
  score Int             @default(0) // ערך ברירת מחדל של ניקוד
  role  ParticipantRole

  // מפתחות זרים (Foreign Keys)
  userId Int
  gameId Int

  // הגדרת הקשרים חזרה למודלים הראשיים
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // אילוץ ייחודיות: משתמש לא יכול להופיע פעמיים באותו משחק
  @@unique([userId, gameId])
}
